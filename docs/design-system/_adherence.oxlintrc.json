{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/feedback/**",
              "components/media/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Oswald|Inter))/i]",
        "message": "Font not provided by the design system. Available: Oswald, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|amber|red|dark)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'amber' | 'red' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|as|href|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, as, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:locale|onLocaleChange|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: locale, onLocaleChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute[name.name='locale'] > Literal[value!=/^(?:EN|ES|DE)$/]",
        "message": "<Footer> locale must be one of 'EN' | 'ES' | 'DE'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:locale|onLocaleChange|active|transparent|onNavigate|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: locale, onLocaleChange, active, transparent, onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute[name.name='locale'] > Literal[value!=/^(?:EN|ES|DE)$/]",
        "message": "<Header> locale must be one of 'EN' | 'ES' | 'DE'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute[name.name='active'] > Literal[value!=/^(?:home|packages|about|contact|reviews)$/]",
        "message": "<Header> active must be one of 'home' | 'packages' | 'about' | 'contact' | 'reviews'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:mail|map-pin|instagram|menu|x|globe|chevronDown|bike|phone)$/]",
        "message": "<Icon> name must be one of 'mail' | 'map-pin' | 'instagram' | 'menu' | 'x' | 'globe' | 'chevronDown' | 'bike' | 'phone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguageSwitcher'] > JSXAttribute > JSXIdentifier[name!=/^(?:locale|onChange|dark|key|ref|className|style|children)$/]",
        "message": "<LanguageSwitcher> doesn't accept that prop. Declared props: locale, onChange, dark."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguageSwitcher'] > JSXAttribute[name.name='locale'] > Literal[value!=/^(?:EN|ES|DE)$/]",
        "message": "<LanguageSwitcher> locale must be one of 'EN' | 'ES' | 'DE'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapEmbed'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|compact|key|ref|className|style|children)$/]",
        "message": "<MapEmbed> doesn't accept that prop. Declared props: label, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='PackageCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|nights|days|price|features|highlight|imageSlot|key|ref|className|style|children)$/]",
        "message": "<PackageCard> doesn't accept that prop. Declared props: name, nights, days, price, features, highlight, imageSlot."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|country|rating|text|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: name, country, rating, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|align|light|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, align, light."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeading> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
