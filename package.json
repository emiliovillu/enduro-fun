{
  "name": "endurofun",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "pnpm --filter @app/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --parallel typecheck",
    "knip": "knip",
    "readme:status": "node scripts/readme-status.mjs",
    "readme:status:check": "node scripts/readme-status.mjs --check",
    "gate": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm knip && pnpm readme:status:check && pnpm test",
    "prepare": "lefthook install",
    "test": "vitest run --project '*:unit'",
    "test:unit": "vitest run --project '*:unit'",
    "test:watch": "vitest --project '*:unit'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitest/eslint-plugin": "catalog:",
    "eslint": "^9.39.1",
    "eslint-config-next": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-playwright": "^2.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jiti": "^2.6.1",
    "knip": "^5.66.4",
    "lefthook": "^1.13.6",
    "prettier": "^3.6.2",
    "typescript": "catalog:",
    "typescript-eslint": "^8.46.4",
    "vitest": "catalog:"
  }
}
